{
  "name": "wfl",
  "version": "0.1.0",
  "description": "Web Formation Language — token-efficient AI-native DSL that compiles to React JSX",
  "type": "module",
  "engines": { "node": ">=18" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wfl": "./dist/index.js"
  },
  "files": [
    "dist"
